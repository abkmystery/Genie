DEMO_GATEWAY_PORT=8788
DEMO_GATEWAY_PROVIDER=gemini_openai

# Google-hosted Gemma 4 via Gemini OpenAI-compatible interface (server-side only).
GEMINI_API_KEY=
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemma-4-26b-a4b-it

# Optional: proxy to another OpenAI-compatible service (server-side only).
DEMO_PROVIDER_URL=https://provider.example.invalid
DEMO_PROVIDER_TOKEN=replace-on-server-only
