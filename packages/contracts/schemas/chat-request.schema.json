{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatRequest",
  "type": "object",
  "required": [
    "prompt"
  ],
  "properties": {
    "prompt": {
      "type": "string"
    },
    "use_current_screen": {
      "type": "boolean"
    },
    "use_region": {
      "type": "boolean"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

